<Window x:Class="AppShoes.Views.OrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AppShoes.Views"
        mc:Ignorable="d"
        Title="Список заказов" Height="450" Width="800" Icon="/Resources/Icon.ico" WindowState="Maximized">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="75"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="#7FFF00">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>
            <Image Source="\Resources\Icon.png"/>
            <Button Content="Добавить заказ" x:Name="AddOrderBtn" Click="AddOrderBtn_Click"  Style="{StaticResource ButtonStyle}" Margin="10 20" Grid.Column="1"/>
            <TextBlock Style="{StaticResource TextBlockStyle}" Text="ООО Обвуь" FontSize="25" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Column="0" Grid.ColumnSpan="4"/>
            <TextBlock Grid.Column="1" x:Name="AppUserTb" Grid.ColumnSpan="3" Background="#7FFF00" VerticalAlignment="Top" HorizontalAlignment="Right" Text="Вы вошли как гость" Style="{StaticResource TextBlockStyle}" FontSize="20"/>
            <TextBlock Style="{StaticResource TextBlockStyle}" x:Name="OrdersNewTb" Text="123" FontSize="25" VerticalAlignment="Center" HorizontalAlignment="Left" Grid.Column="2"/>
            <Button Content="Назад" x:Name="BackBtn" Grid.Column="3" Margin="10 20" Style="{StaticResource ButtonStyle}" Click="BackBtn_Click"/>
        </Grid>

        <ListView HorizontalContentAlignment="Stretch" x:Name="OrdersLv" Grid.Row="1">
            <ListView.ContextMenu>
                <ContextMenu x:Name="EditMenu">
                    <MenuItem x:Name="EditTovarMi" Click="EditOrderMi_Click"  Header="Редактировать"/>
                    <MenuItem x:Name="DeleteTovarMi" Click="DeleteOrderMi_Click"  Header="Удалить"/>
                </ContextMenu>
            </ListView.ContextMenu>
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical"/>
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
        </ListView>

    </Grid>
</Window>
