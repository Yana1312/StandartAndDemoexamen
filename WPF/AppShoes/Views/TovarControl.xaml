<UserControl x:Class="AppShoes.Views.TovarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AppShoes.Views"
             mc:Ignorable="d" 
             d:DesignHeight="250" d:DesignWidth="800">
    <Border x:Name="BackBorder" BorderBrush="#7FFF00" BorderThickness="1" CornerRadius="20" Margin="5">
        <Grid Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>
            <Image Margin="10 0" Grid.Column="0" x:Name="TovarsImg" Source="{Binding FullPath}" Stretch="UniformToFill"/>
            <StackPanel Grid.Column="1">
                <TextBlock Style="{StaticResource TextBlockStyle}">
                    <Run Text="{Binding CategoryName,Mode=OneWay, FallbackValue='Категория товара отсутствует'}"/>
                    <Run>|</Run>
                    <Run Text="{Binding TovarTitle, FallbackValue='Наименование товара отсутствует'}"/>
                </TextBlock>
                <TextBlock Style="{StaticResource TextBlockStyle}" Text="{Binding TovarDescription, StringFormat='Описание: {0}'}"/>
                <TextBlock Style="{StaticResource TextBlockStyle}" Text="{Binding ManufacturName,Mode=OneWay, StringFormat='Производитель: {0}'}"/>
                <TextBlock Style="{StaticResource TextBlockStyle}" Text="{Binding SupplierName,Mode=OneWay, StringFormat='Поставщик: {0}'}"/>

                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="PriceLabelTb" Style="{StaticResource TextBlockStyle}" Text="Цена: "/>
                    <TextBlock x:Name="FirstCostTb" Style="{StaticResource TextBlockStyle}" Text="{Binding TovarCost}"/>
                    <TextBlock x:Name="FinalCostTb" Style="{StaticResource TextBlockStyle}" Foreground="Black" Visibility="Hidden"/>
                </StackPanel>

                <TextBlock Style="{StaticResource TextBlockStyle}" Text="{Binding TovarUnit, StringFormat='Единица измерения: {0}'}"/>
                <TextBlock x:Name="CountTovarTb" Style="{StaticResource TextBlockStyle}" Text="{Binding TovarCount, StringFormat='Количество на складе: {0}'}"/>
            </StackPanel>
            <TextBlock x:Name="CurSaleTb" Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center" Text="{Binding TovarSale, StringFormat={}{0}%}" Style="{StaticResource TextBlockStyle}" FontSize="20"/>
        </Grid>
    </Border>
</UserControl>