<Window x:Class="AppShoes.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AppShoes"
        mc:Ignorable="d"
        Title="Авторизация" Height="450" Width="800" Icon="/Resources/Icon.ico" WindowState="Maximized">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="75"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        
        <Grid Grid.Row="0" Background="#7FFF00">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="150"/>
            </Grid.ColumnDefinitions>
            <Image Source="\Resources\Icon.png"/>
            <TextBlock Style="{StaticResource TextBlockStyle}" Text="ООО Обувь" FontSize="25" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Column="0" Grid.ColumnSpan="3"/>
            <Button x:Name="GuestAuthBtn" Grid.Column="2" Content="Войти как гость" Style="{StaticResource ButtonStyle}" Margin="5 15" Click="GuestAuthBtn_Click"/>
        </Grid>
        
        
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="200" Height="150" Grid.Row="1">
            <TextBlock Style="{StaticResource TextBlockStyle}" Text="Введите логин"/>
            <TextBox x:Name="LoginTbox" Style="{StaticResource TextBoxStyle}" Text="94d5ous@gmail.com"/>
            <TextBlock Style="{StaticResource TextBlockStyle}" Text="Введите пароль"/>
            <TextBox x:Name="PasswordTbox" Style="{StaticResource TextBoxStyle}" Text="uzWC67"/>
            <Button Name="AuthBtn" Content="Войти" Style="{StaticResource ButtonStyle}" Margin="0 5" Click="AuthBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
